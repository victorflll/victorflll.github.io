---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Repos from '../components/Repos.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Victor — Software Developer">
  <Header />
  <main>
    <Hero />
    <About />
    <Experience />
    <Education />
    <Repos />
    <Contact />
  </main>
  <Footer />

  <script>
    import { strings, type Lang } from '../i18n/strings';

    // ---------- i18n ----------
    function getLang(): Lang {
      const stored = localStorage.getItem('lang') as Lang | null;
      if (stored === 'pt' || stored === 'en') return stored;
      return navigator.language?.toLowerCase().startsWith('pt') ? 'pt' : 'en';
    }
    function applyLang(lang: Lang) {
      document.documentElement.lang = lang === 'pt' ? 'pt-BR' : 'en';
      document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
        const key = el.dataset.i18n!;
        const val = strings[lang][key];
        if (val) el.textContent = val;
      });
      localStorage.setItem('lang', lang);
    }
    let currentLang = getLang();
    applyLang(currentLang);
    document.getElementById('lang-toggle')?.addEventListener('click', () => {
      currentLang = currentLang === 'pt' ? 'en' : 'pt';
      applyLang(currentLang);
      loadRepos();
    });

    // ---------- Theme ----------
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // ---------- GitHub repos ----------
    type Repo = {
      name: string;
      description: string | null;
      html_url: string;
      language: string | null;
      stargazers_count: number;
      fork: boolean;
      updated_at: string;
    };

    const PINNED = ['miauche', 'chat-socket-java', 't-work', 'tein-blazeface', 'serverside-application-example'];
    const FALLBACK: Repo[] = [
      { name: 'miauche', description: 'Flutter app for reporting lost/found pets in Arapiraca', html_url: 'https://github.com/victorflll/miauche', language: 'Dart', stargazers_count: 0, fork: false, updated_at: '' },
      { name: 'chat-socket-java', description: 'Messaging app built with Java sockets', html_url: 'https://github.com/victorflll/chat-socket-java', language: 'Java', stargazers_count: 0, fork: false, updated_at: '' },
      { name: 't-work', description: 'OOP course final project (2019)', html_url: 'https://github.com/victorflll/t-work', language: 'Java', stargazers_count: 0, fork: false, updated_at: '' },
      { name: 'tein-blazeface', description: 'Face detection experiment', html_url: 'https://github.com/victorflll/tein-blazeface', language: 'JavaScript', stargazers_count: 0, fork: false, updated_at: '' },
      { name: 'serverside-application-example', description: 'Node.js academic project with DB integration', html_url: 'https://github.com/victorflll/serverside-application-example', language: 'JavaScript', stargazers_count: 0, fork: false, updated_at: '' },
    ];

    const LANG_COLORS: Record<string, string> = {
      JavaScript: '#f1e05a', TypeScript: '#3178c6', Java: '#b07219', Python: '#3572A5',
      Dart: '#00B4AB', HTML: '#e34c26', CSS: '#563d7c', Go: '#00ADD8', Rust: '#dea584',
      Kotlin: '#A97BFF', C: '#555555', 'C++': '#f34b7d', Shell: '#89e051',
    };

    function renderRepos(repos: Repo[], errored = false) {
      const grid = document.getElementById('repos-grid');
      if (!grid) return;
      grid.innerHTML = '';

      if (errored) {
        const note = document.createElement('p');
        note.className = 'muted';
        note.textContent = strings[currentLang]['projects.error'];
        note.style.gridColumn = '1 / -1';
        grid.appendChild(note);
      }

      repos.forEach((r) => {
        const a = document.createElement('a');
        a.href = r.html_url;
        a.target = '_blank';
        a.rel = 'noopener';
        a.className = 'card';
        const langDot = r.language
          ? `<span class="lang-dot" style="background:${LANG_COLORS[r.language] || '#888'}"></span>${r.language}`
          : '';
        a.innerHTML = `
          <h3>${r.name}</h3>
          <p>${r.description ?? ''}</p>
          <div class="meta">
            <span>${langDot}</span>
            ${r.stargazers_count ? `<span>★ ${r.stargazers_count}</span>` : ''}
          </div>
        `;
        grid.appendChild(a);
      });
    }

    async function loadRepos() {
      const cached = sessionStorage.getItem('gh-repos');
      if (cached) {
        try { renderRepos(JSON.parse(cached)); return; } catch {}
      }
      try {
        const res = await fetch('https://api.github.com/users/victorflll/repos?per_page=100&sort=updated');
        if (!res.ok) throw new Error('rate-limit');
        const all: Repo[] = await res.json();
        const own = all.filter((r) => !r.fork);
        const pinned = PINNED.map((n) => own.find((r) => r.name === n)).filter(Boolean) as Repo[];
        const others = own.filter((r) => !PINNED.includes(r.name)).slice(0, 6 - pinned.length);
        const finalList = [...pinned, ...others].slice(0, 6);
        sessionStorage.setItem('gh-repos', JSON.stringify(finalList));
        renderRepos(finalList);
      } catch {
        renderRepos(FALLBACK, true);
      }
    }
    loadRepos();

    // ---------- Reveal on scroll ----------
    document.querySelectorAll('section').forEach((s) => s.classList.add('reveal'));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</Base>
