---
<section class="hero">
  <div class="container hero-row">
    <img
      class="avatar"
      src="https://github.com/victorflll.png"
      alt="Victor"
      width="160"
      height="160"
      loading="eager"
    />
    <div class="hero-text">
      <h1 data-i18n="hero.title">Victor Lemos</h1>
      <p class="lead"><span data-i18n="hero.role">Software Developer @ Darkmatter</span></p>
      <p class="muted" data-i18n="hero.location">Maceió, Brasil</p>
      <div class="links">
        <a class="btn primary" href="https://github.com/victorflll" target="_blank" rel="noopener" data-i18n="hero.cta.github">GitHub</a>
        <a class="btn" href="#contact" data-i18n="hero.cta.contact">Entrar em contato</a>
      </div>
    </div>
  </div>
</section>
